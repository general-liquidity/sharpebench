# Rust build output
/target
# crates/sharpebench-py is excluded from the workspace (pyo3 extension-module), so it
# builds into its own target dir, which the root-anchored rule above does not cover.
/crates/sharpebench-py/target
**/*.rs.bk

# Python build/test scratch from the sharpebench-py binding
__pycache__/
.pytest_cache/
*.pyd
*.so

# Generated WASM JS bindings (run scripts/build-wasm.sh)
/pkg

# Generated mdbook output (run `mdbook build docs/book`)
/docs/book/book

# We intentionally COMMIT Cargo.lock — reproducible scores require a pinned
# dependency graph. (Generate it with `cargo build` on first checkout.)

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
